# NoteCast Environment Variables
# Copy this file to .env and fill in the values

# Required: Public URL where the podcast will be accessible (used in RSS episode links)
BASE_URL=https://your-domain.com

# Required: Domain for Caddy HTTPS (same as BASE_URL host)
CADDY_DOMAIN=your-domain.com

# Optional: Seconds between polls for new artifacts (default: 86400 = once a day)
POLL_INTERVAL=86400

# Optional: Number of days to retain episodes (default: 14)
RETENTION_DAYS=14

# Optional: Port for the bridge HTTP API (default: 8080)
BRIDGE_PORT=8080

# Optional: API key to protect /auth/upload (leave empty to disable auth)
BRIDGE_API_KEY=

# Optional: Cover image URL for the podcast feed (1400x1400px recommended)
FEED_IMAGE_URL=

# Optional: faster-whisper model for non-YouTube transcription (tiny/base/small/medium/large-v3)
# WHISPER_MODEL=base

# ── Multi-user (optional) ─────────────────────────────────────────────────────

# Comma-separated user names. Leave empty for single-user mode (no auth required).
USERS=
# Per-user Google email (must match the Google account used to sign in)
# USER_ALICE_EMAIL=alice@gmail.com
# USER_BOB_EMAIL=bob@gmail.com
# Per-user webhook overrides (fall back to global WEBHOOK_* if not set)
# USER_ALICE_WEBHOOK_URL=https://ntfy.sh/alice-notecast
# USER_ALICE_WEBHOOK_HEADERS={"Authorization": "Bearer yourtoken"}
# USER_ALICE_WEBHOOK_LINK=https://podcasts.apple.com/...
# USER_BOB_WEBHOOK_URL=https://ntfy.sh/bob-notecast
# USER_BOB_WEBHOOK_HEADERS={"Authorization": "Bearer yourtoken"}
# USER_BOB_WEBHOOK_LINK=https://podcasts.apple.com/...

# Google OAuth2 client ID for the web UI (create at console.cloud.google.com)
# Required when USERS is set (multi-user mode). Leave empty for single-user (no sign-in).
# Authorised JavaScript origin: your BASE_URL. Authorised redirect URI: not needed (implicit flow).
GOOGLE_CLIENT_ID=

# ── Notifications ─────────────────────────────────────────────────────────────

# Optional: Webhook URL to POST when a new episode is downloaded (ntfy, Slack, Discord, etc.)
WEBHOOK_URL=
# Optional: JSON object of HTTP headers sent with each webhook request (e.g. for ntfy auth)
# WEBHOOK_HEADERS={"Authorization": "Bearer yourtoken"}
WEBHOOK_HEADERS=
# Optional: URL included as "click" field in ntfy notifications (e.g. Apple Podcasts shortcut)
WEBHOOK_LINK=

# Optional: Days before token expiry to send notification (default: 7)
TOKEN_EXPIRY_WARN_DAYS=7

# Optional: Base directory for data storage (default: /data in container, ./data locally)
DATA_BASE=/data

# Optional: Base directory for public files (default: /public in container, ./public locally)
PUBLIC_DIR=/public