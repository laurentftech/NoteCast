(notecast) {
    encode gzip

    handle /api/* {
        reverse_proxy notecast-bridge:8080
    }
    handle /auth/* {
        reverse_proxy notecast-bridge:8080
    }
    handle /health {
        reverse_proxy notecast-bridge:8080
    }

    handle /index.html {
        root * /srv
        file_server
        header Cache-Control "no-store"
    }

    handle / {
        root * /srv
        file_server
        header Cache-Control "no-store"
    }

    handle {
        root * /srv
        file_server
    }
}

{$CADDY_DOMAIN} {
    import notecast
}

http://localhost {
    import notecast
}
