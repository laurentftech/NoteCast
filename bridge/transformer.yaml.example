# Feeds are NOT shared between users.
# Single-user mode: set rss_feeds as a list.
# Multi-user mode: set rss_feeds as a map keyed by user name.
rss_feeds:
  laurent:
    - name: tech-news
      url: "https://example.com/feed.xml"
      style: deep-dive
  armelle:
    - name: product-updates
      url: "https://another.com/rss"
      style: brief

# Seconds between RSS polls (default: 30 min)
poll_interval_minutes: 30

notebooklm:
  # Fallback style when feed doesn't specify one
  # Options: brief | deep-dive | critique | debate
  default_style: deep-dive

  # Optional: custom instructions passed to NotebookLM audio generation
  # instructions: "Create a clear spoken French podcast summarizing the episode."
